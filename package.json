{
  "name": "terminal-recipes",
  "displayName": "Terminal Recipes",
  "description": "Manage categorized terminal commands and run, use, or copy them with variable support.",
  "version": "1.0.0",
  "publisher": "abdulla-aldosari",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "Terminal",
    "Commands",
    "Command Line",
    "CLI",
    "CMD",
    "Shell",
    "PowerShell",
    "Run",
    "Productivity",
    "Runner",
    "Manager",
    "AI",
    "Variables",
    "Favorites"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "terminalRecipes.openPanel",
        "title": "Terminal Recipes: Open Panel"
      }
    ],
    "keybindings": [
      {
        "command": "terminalRecipes.openPanel",
        "key": "f4 f4",
        "mac": "f4 f4"
      }
    ],
    "configuration": {
      "title": "Terminal Recipes",
      "properties": {
        "terminalRecipes.aiProvider": {
          "type": "string",
          "enum": [
            "gemini",
            "openai",
            "anthropic",
            "deepseek",
            "groq",
            "mistral",
            "cohere",
            "stepfun"
          ],
          "enumDescriptions": [
            "Google Gemini — free models available",
            "OpenAI ChatGPT",
            "Anthropic Claude",
            "DeepSeek — very low cost, free tier available",
            "Groq — free tier with fast inference",
            "Mistral AI — free models available",
            "Cohere — free trial available",
            "StepFun — free model available"
          ],
          "default": "gemini",
          "description": "The AI provider to use for generating terminal commands."
        },
        "terminalRecipes.aiModel": {
          "type": "string",
          "default": "",
          "description": "The model ID to use for the selected AI provider. Leave empty to use the provider's default model. This is set automatically when you select a model in AI Settings."
        },
        "terminalRecipes.customSystemInstructions": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom system instructions for the AI command generator. Leave empty to use the default instructions."
        },
        "terminalRecipes.debugOutput": {
          "type": "boolean",
          "default": false,
          "description": "Enable detailed debug output in the VS Code Output Channel (Terminal Recipes). Logs internal operations such as AI requests, model listings, and other extension events."
        }
      }
    }
  },
  "scripts": {
    "check": "node --check extension.js && node --check media/main.js",
    "lint": "eslint extension.js media/main.js lib/",
    "build": "esbuild extension.js --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18 --minify",
    "watch": "esbuild extension.js --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18 --sourcemap --watch",
    "vscode:prepublish": "npm run build",
    "test": "node testing/syntax.test.js && node testing/normalize.test.js && node testing/terminal.test.js && node testing/exports.test.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulla-Aldosari/vscode-terminal-recipes"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.5",
    "cohere-ai": "^8.0.0",
    "groq-sdk": "^1.2.1",
    "openai": "^4.103.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1"
  }
}
