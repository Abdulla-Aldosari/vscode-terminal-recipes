{
  "name": "terminal-recipes",
  "displayName": "Terminal Recipes",
  "description": "Manage categorized terminal commands and run, use, or copy them with variable support.",
  "version": "0.0.1",
  "publisher": "abdulla-aldosari",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalRecipes.openPanel",
        "title": "Terminal Recipes: Open Panel"
      }
    ],
    "keybindings": [
      {
        "command": "terminalRecipes.openPanel",
        "key": "f4 f4",
        "mac": "f4 f4"
      }
    ],
    "configuration": {
      "title": "Terminal Recipes",
      "properties": {
        "terminalRecipes.aiProvider": {
          "type": "string",
          "enum": [
            "gemini",
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "Google Gemini (gemini-flash-latest)",
            "OpenAI ChatGPT (gpt-4.1)",
            "Anthropic Claude (claude-sonnet-4-6)"
          ],
          "default": "gemini",
          "description": "The AI provider to use for generating terminal commands."
        },
        "terminalRecipes.customSystemInstructions": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom system instructions for the AI command generator. Leave empty to use the default instructions."
        },
        "terminalRecipes.aiDebugOutput": {
          "type": "boolean",
          "default": false,
          "description": "Show AI request and response payloads in the VS Code Output Channel (Terminal Recipes AI). Useful for inspecting the request body and verifying that the AI response matches the expected JSON schema."
        }
      }
    }
  },
  "scripts": {
    "check": "node --check extension.js && node --check media/main.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulla-Aldosari/vscode-terminal-recipes"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.1",
    "openai": "^4.103.0"
  }
}